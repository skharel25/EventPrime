@page "/contact"

<PageTitle>Contact – EventPrime</PageTitle>

<!-- Page Banner -->
<section class="page-banner">
    <div class="banner-shapes">
        <div class="banner-shape bs-1"></div>
        <div class="banner-shape bs-2"></div>
    </div>
    <div class="container banner-body">
        <div class="section-tag">Get in Touch</div>
        <h1 class="banner-title">Contact Us</h1>
        <p class="banner-subtitle">Have a question, partnership idea, or need event support? We'd love to hear from you.</p>
    </div>
</section>

<!-- Contact Section -->
<section class="contact-section">
    <div class="container">
        <div class="contact-grid">
            <!-- Info Column -->
            <div class="contact-info">
                <div class="info-card">
                    <span class="info-icon">📍</span>
                    <div>
                        <h4 class="info-title">Our Office</h4>
                        <p class="info-text">350 Fifth Avenue, Suite 7800<br />New York, NY 10118</p>
                    </div>
                </div>
                <div class="info-card">
                    <span class="info-icon">📧</span>
                    <div>
                        <h4 class="info-title">Email Us</h4>
                        <p class="info-text"><a href="mailto:hello@eventprime.com">hello@eventprime.com</a></p>
                        <p class="info-text"><a href="mailto:support@eventprime.com">support@eventprime.com</a></p>
                    </div>
                </div>
                <div class="info-card">
                    <span class="info-icon">📞</span>
                    <div>
                        <h4 class="info-title">Call Us</h4>
                        <p class="info-text">+1 (800) 555-0199</p>
                        <p class="info-sub">Mon–Fri, 9 AM – 6 PM EST</p>
                    </div>
                </div>
                <div class="info-card">
                    <span class="info-icon">💬</span>
                    <div>
                        <h4 class="info-title">Live Chat</h4>
                        <p class="info-text">Available on weekdays during business hours.</p>
                    </div>
                </div>
            </div>

            <!-- Form Column -->
            <div class="contact-form-wrap">
                <h2 class="form-heading">Send Us a Message</h2>
                <p class="form-sub">We typically respond within 24 hours.</p>
                <form class="contact-form" novalidate>
                    <div class="form-row">
                        <div class="form-field">
                            <label class="field-label">First Name</label>
                            <input type="text" class="field-input" placeholder="Jane" />
                        </div>
                        <div class="form-field">
                            <label class="field-label">Last Name</label>
                            <input type="text" class="field-input" placeholder="Doe" />
                        </div>
                    </div>
                    <div class="form-field">
                        <label class="field-label">Email Address</label>
                        <input type="email" class="field-input" placeholder="jane@example.com" />
                    </div>
                    <div class="form-field">
                        <label class="field-label">Subject</label>
                        <select class="field-input">
                            <option value="">Select a topic…</option>
                            <option>General Inquiry</option>
                            <option>Event Listing Request</option>
                            <option>Partnership / Sponsorship</option>
                            <option>Technical Support</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="form-field">
                        <label class="field-label">Message</label>
                        <textarea class="field-input field-textarea" placeholder="Tell us how we can help…" rows="5"></textarea>
                    </div>
                    <button type="submit" class="btn-submit">Send Message 🚀</button>
                </form>
            </div>
        </div>
    </div>
</section>
