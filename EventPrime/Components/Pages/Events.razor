@page "/events"

<PageTitle>Events – EventPrime</PageTitle>

<!-- Page Banner -->
<section class="page-banner">
    <div class="banner-shapes">
        <div class="banner-shape bs-1"></div>
        <div class="banner-shape bs-2"></div>
    </div>
    <div class="container banner-body">
        <div class="section-tag">Discover</div>
        <h1 class="banner-title">All Events</h1>
        <p class="banner-subtitle">Browse hundreds of curated events happening near you and around the world.</p>
    </div>
</section>

<!-- Filter Bar -->
<section class="filter-bar-section">
    <div class="container">
        <div class="filter-bar">
            <div class="filter-group">
                <label class="filter-label">Category</label>
                <select class="filter-select">
                    <option>All Categories</option>
                    <option>Music</option>
                    <option>Business</option>
                    <option>Arts</option>
                    <option>Sports</option>
                    <option>Food</option>
                    <option>Education</option>
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">Location</label>
                <select class="filter-select">
                    <option>All Locations</option>
                    <option>New York</option>
                    <option>Los Angeles</option>
                    <option>Chicago</option>
                    <option>Houston</option>
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">Date</label>
                <select class="filter-select">
                    <option>Any Date</option>
                    <option>This Week</option>
                    <option>This Month</option>
                    <option>Next 3 Months</option>
                </select>
            </div>
            <button class="btn-filter-apply">Apply Filters</button>
        </div>
    </div>
</section>

<!-- Events Listing -->
<section class="events-listing-section">
    <div class="container">
        <h2 class="listing-title">Upcoming Events <span class="listing-count">12 events found</span></h2>
        <div class="listing-grid">

            <div class="listing-card">
                <div class="listing-banner banner-music"></div>
                <div class="listing-body">
                    <div class="listing-meta">
                        <span class="listing-category cat-music">🎵 Music</span>
                        <span class="listing-price">From $49</span>
                    </div>
                    <h3 class="listing-title-text">SoundWave Music Festival</h3>
                    <p class="listing-detail">📅 May 15–17, 2026 &nbsp;|&nbsp; 📍 Central Park, New York</p>
                    <p class="listing-desc">Three days of non-stop live music across 5 stages with 80+ world-class artists.</p>
                    <a href="#" class="btn-listing">Get Tickets →</a>
                </div>
            </div>

            <div class="listing-card">
                <div class="listing-banner banner-tech"></div>
                <div class="listing-body">
                    <div class="listing-meta">
                        <span class="listing-category cat-tech">💻 Tech</span>
                        <span class="listing-price">From $129</span>
                    </div>
                    <h3 class="listing-title-text">TechForward Summit 2026</h3>
                    <p class="listing-detail">📅 Jun 3, 2026 &nbsp;|&nbsp; 📍 Moscone Center, San Francisco</p>
                    <p class="listing-desc">Join industry leaders to explore AI, cloud computing, and the future of technology.</p>
                    <a href="#" class="btn-listing">Get Tickets →</a>
                </div>
            </div>

            <div class="listing-card">
                <div class="listing-banner banner-food"></div>
                <div class="listing-body">
                    <div class="listing-meta">
                        <span class="listing-category cat-food">🍴 Food</span>
                        <span class="listing-price">From $25</span>
                    </div>
                    <h3 class="listing-title-text">Global Food Carnival</h3>
                    <p class="listing-detail">📅 Jun 20, 2026 &nbsp;|&nbsp; 📍 Millennium Park, Chicago</p>
                    <p class="listing-desc">Sample cuisines from over 40 countries with live cooking demonstrations.</p>
                    <a href="#" class="btn-listing">Get Tickets →</a>
                </div>
            </div>

            <div class="listing-card">
                <div class="listing-banner banner-arts"></div>
                <div class="listing-body">
                    <div class="listing-meta">
                        <span class="listing-category cat-arts">🎨 Arts</span>
                        <span class="listing-price">From $35</span>
                    </div>
                    <h3 class="listing-title-text">ModernArt Expo 2026</h3>
                    <p class="listing-detail">📅 Jul 5–8, 2026 &nbsp;|&nbsp; 📍 Getty Center, Los Angeles</p>
                    <p class="listing-desc">A stunning showcase of contemporary art from over 200 global artists.</p>
                    <a href="#" class="btn-listing">Get Tickets →</a>
                </div>
            </div>

            <div class="listing-card">
                <div class="listing-banner banner-sports"></div>
                <div class="listing-body">
                    <div class="listing-meta">
                        <span class="listing-category cat-sports">🏋️ Sports</span>
                        <span class="listing-price">Free</span>
                    </div>
                    <h3 class="listing-title-text">City Marathon 2026</h3>
                    <p class="listing-detail">📅 Jul 12, 2026 &nbsp;|&nbsp; 📍 Downtown Houston</p>
                    <p class="listing-desc">Run through the heart of the city in this annual 26.2-mile community marathon.</p>
                    <a href="#" class="btn-listing">Register →</a>
                </div>
            </div>

            <div class="listing-card">
                <div class="listing-banner banner-edu"></div>
                <div class="listing-body">
                    <div class="listing-meta">
                        <span class="listing-category cat-edu">🎓 Education</span>
                        <span class="listing-price">From $79</span>
                    </div>
                    <h3 class="listing-title-text">LearnX Conference 2026</h3>
                    <p class="listing-detail">📅 Aug 1–2, 2026 &nbsp;|&nbsp; 📍 Boston Convention Center</p>
                    <p class="listing-desc">The premier education and e-learning summit featuring 50+ workshops and keynotes.</p>
                    <a href="#" class="btn-listing">Get Tickets →</a>
                </div>
            </div>

        </div>

        <div class="pagination-bar">
            <button class="pg-btn active">1</button>
            <button class="pg-btn">2</button>
            <button class="pg-btn">3</button>
            <button class="pg-btn pg-next">Next →</button>
        </div>
    </div>
</section>
