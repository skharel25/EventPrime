@page "/"

<PageTitle>EventPrime – Discover Amazing Events</PageTitle>

<!-- Hero Banner -->
<section class="hero-banner">
    <div class="hero-bg-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>
    <div class="container hero-content">
        <div class="hero-badge">🎉 Your Event Journey Starts Here</div>
        <h1 class="hero-title">
            Discover &amp; Experience<br />
            <span class="hero-title-accent">Extraordinary Events</span>
        </h1>
        <p class="hero-subtitle">
            From concerts and conferences to festivals and workshops — find the perfect event
            and create memories that last a lifetime.
        </p>
        <div class="hero-actions">
            <a href="/events" class="btn btn-hero-primary">Explore Events</a>
            <a href="/contact" class="btn btn-hero-secondary">Get in Touch</a>
        </div>
        <div class="hero-stats">
            <div class="stat-item">
                <span class="stat-number">500+</span>
                <span class="stat-label">Events Listed</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number">50K+</span>
                <span class="stat-label">Happy Attendees</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number">100+</span>
                <span class="stat-label">Cities Covered</span>
            </div>
        </div>
    </div>
</section>

<!-- Category Strip -->
<section class="category-strip">
    <div class="container">
        <div class="category-grid">
            <a href="/events" class="category-card">
                <span class="category-icon">🎵</span>
                <span class="category-name">Music</span>
            </a>
            <a href="/events" class="category-card">
                <span class="category-icon">💼</span>
                <span class="category-name">Business</span>
            </a>
            <a href="/events" class="category-card">
                <span class="category-icon">🎨</span>
                <span class="category-name">Arts</span>
            </a>
            <a href="/events" class="category-card">
                <span class="category-icon">🏋️</span>
                <span class="category-name">Sports</span>
            </a>
            <a href="/events" class="category-card">
                <span class="category-icon">🍴</span>
                <span class="category-name">Food</span>
            </a>
            <a href="/events" class="category-card">
                <span class="category-icon">🎓</span>
                <span class="category-name">Education</span>
            </a>
        </div>
    </div>
</section>

<!-- Featured Events Section -->
<section class="section-block">
    <div class="container">
        <div class="section-header">
            <div class="section-tag">Featured</div>
            <h2 class="section-title">Upcoming Events</h2>
            <p class="section-subtitle">Don't miss out on these handpicked experiences</p>
        </div>
        <div class="events-grid">
            <div class="event-card">
                <div class="event-card-banner banner-music">
                    <span class="event-card-category">🎵 Music</span>
                </div>
                <div class="event-card-body">
                    <p class="event-card-date">📅 May 15, 2026 · 7:00 PM</p>
                    <h3 class="event-card-title">SoundWave Music Festival</h3>
                    <p class="event-card-desc">Three days of non-stop live music across 5 stages with 80+ artists.</p>
                    <div class="event-card-footer">
                        <span class="event-price">From $49</span>
                        <a href="/events" class="btn-event-link">Get Tickets →</a>
                    </div>
                </div>
            </div>
            <div class="event-card">
                <div class="event-card-banner banner-tech">
                    <span class="event-card-category">💻 Tech</span>
                </div>
                <div class="event-card-body">
                    <p class="event-card-date">📅 Jun 3, 2026 · 9:00 AM</p>
                    <h3 class="event-card-title">TechForward Summit 2026</h3>
                    <p class="event-card-desc">Join industry leaders to explore AI, cloud computing, and the future of tech.</p>
                    <div class="event-card-footer">
                        <span class="event-price">From $129</span>
                        <a href="/events" class="btn-event-link">Get Tickets →</a>
                    </div>
                </div>
            </div>
            <div class="event-card">
                <div class="event-card-banner banner-food">
                    <span class="event-card-category">🍴 Food</span>
                </div>
                <div class="event-card-body">
                    <p class="event-card-date">📅 Jun 20, 2026 · 12:00 PM</p>
                    <h3 class="event-card-title">Global Food Carnival</h3>
                    <p class="event-card-desc">Sample cuisines from over 40 countries with live cooking demonstrations.</p>
                    <div class="event-card-footer">
                        <span class="event-price">From $25</span>
                        <a href="/events" class="btn-event-link">Get Tickets →</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-5">
            <a href="/events" class="btn btn-outline-brand">View All Events</a>
        </div>
    </div>
</section>

<!-- Why EventPrime -->
<section class="section-block section-dark">
    <div class="container">
        <div class="section-header light">
            <div class="section-tag">Why Us</div>
            <h2 class="section-title">The EventPrime Difference</h2>
            <p class="section-subtitle">Everything you need for an unforgettable experience</p>
        </div>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🔍</div>
                <h4>Easy Discovery</h4>
                <p>Find events by location, category, or date with our powerful search.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🎟️</div>
                <h4>Secure Tickets</h4>
                <p>Purchase tickets safely with our encrypted, trusted payment system.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📱</div>
                <h4>Mobile Ready</h4>
                <p>Access your tickets and event info on any device, anytime.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🌟</div>
                <h4>Curated Quality</h4>
                <p>Every event is vetted to ensure you get the best experience.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA Banner -->
<section class="cta-banner">
    <div class="cta-bg-shapes">
        <div class="cta-shape cta-shape-1"></div>
        <div class="cta-shape cta-shape-2"></div>
    </div>
    <div class="container cta-content">
        <h2 class="cta-title">Ready to Find Your Next Adventure?</h2>
        <p class="cta-subtitle">Join thousands of event-goers who trust EventPrime every day.</p>
        <a href="/events" class="btn btn-cta-white">Browse Events Now</a>
    </div>
</section>

